{
  "name": "gelato-print-agent",
  "version": "1.0.0",
  "description": "Local BLE Print Agent for Gelato Print WebApp",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "electron": "electron electron/main.js",
    "dist": "electron-builder --win --x64",
    "postinstall": "electron-rebuild -f -w @abandonware/noble || echo 'electron-rebuild skipped'"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-26",
    "@resvg/resvg-js": "^2.6.2",
    "bonjour-service": "^1.2.1",
    "express": "^4.18.3",
    "jimp": "^0.22.12"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "build": {
    "appId": "com.gelato.printagent",
    "productName": "GelatoPrintAgent",
    "files": [
      "electron/**/*",
      "src/**/*",
      "data/**/*",
      "node_modules/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/@abandonware/noble/**",
      "**/node_modules/@resvg/resvg-js/**"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "directories": {
      "output": "dist"
    }
  }
}
